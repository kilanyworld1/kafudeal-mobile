{
  "expo": {
    "name": "KafuDeal",
    "slug": "kafudeal",
    "version": "0.11.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kafudeal",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B2C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kafudeal.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B2C"
      },
      "package": "com.kafudeal.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": ["expo-router", "expo-apple-authentication"],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "36d4b269-b76f-44dd-aaf8-af57815c09a7"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "kafudeals-organization"
  }
}
